{
  "name": "jouwloon",
  "version": "0.1.0",
  "description": "Node.js client for fetching Jouwloon data such as schedules and calendar shifts.",
  "keywords": [
    "jouwloon",
    "schedule",
    "calendar",
    "shifts",
    "node"
  ],
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/jouwloon.js",
  "types": "./dist/jouwloon.d.ts",
  "author": {
    "name": "Max Swart",
    "email": "mail@maxswart.nl",
    "url": "https://maxswart.nl"
  },
  "exports": {
    ".": {
      "types": "./dist/jouwloon.d.ts",
      "import": "./dist/jouwloon.js",
      "default": "./dist/jouwloon.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hypermax6/jouwloon.git"
  },
  "homepage": "https://github.com/hypermax6/jouwloon#readme",
  "bugs": {
    "url": "https://github.com/hypermax6/jouwloon/issues"
  },
  "scripts": {
    "check": "tsc -p ./tsconfig.json --noEmit",
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc -p ./tsconfig.production.json && tsc-alias -p ./tsconfig.production.json",
    "prepublishOnly": "npm run check && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "node-html-parser": "^7.1.0"
  }
}
